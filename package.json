{
  "name": "gasyori100knockjs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "画像処理100本ノックを TypeScript + Canvas API で解く",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s-yoshiki/Gasyori100knockJS.git"
  },
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && biome check . && vitest run"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.5",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "jsdom": "^29.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
