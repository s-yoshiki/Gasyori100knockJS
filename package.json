{
  "name": "gasyori100knockjs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "画像処理100本ノックを TypeScript + Canvas API で解く",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/s-yoshiki/Gasyori100knockJS.git"
  },
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "gen:registry": "node scripts/gen-registry.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.0.0",
    "jsdom": "^29.0.0",
    "prettier": "^3.9.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
